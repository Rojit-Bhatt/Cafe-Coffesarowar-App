# API base URL for the backend. Leave empty (or omit) to use relative paths
# — required for LAN/mobile testing, since a phone's "localhost" means the
# phone itself, not your laptop. Vite's dev-server proxy (vite.config.ts)
# forwards relative /api/* requests to the backend regardless of what host/IP
# the browser used to reach the frontend.
VITE_API_BASE_URL=

# Google OAuth Web application Client ID — same value as the backend's
# GOOGLE_CLIENT_ID (backend/.env). Leave unset to hide the Google sign-in
# button entirely (it degrades gracefully).
VITE_GOOGLE_CLIENT_ID=
