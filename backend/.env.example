# Copy to .env and fill in real values. Every var below has a safe dev
# fallback (see backend/server.js / backend/services/*), so the app runs
# with zero configuration — this file documents what to set for real
# testing/production instead of relying on those fallbacks.

# --- Core (required in production) ---

# Signs/verifies all JWTs. Dev fallback: an insecure hardcoded key (server.js
# refuses to boot with the fallback if NODE_ENV=production). Generate a real
# one with: openssl rand -hex 32
JWT_SECRET=

# Real MongoDB connection string (Atlas or otherwise). Dev fallback: an
# in-memory mock DB (utils/mockMongoose.js) — data doesn't persist across
# restarts and isn't shared across serverless invocations.
MONGODB_URI=

# How long an issued JWT stays valid. Dev fallback: 7d
JWT_EXPIRES_IN=7d

# Express listen port. Dev fallback: 5001
PORT=5001

# Comma-separated list of origins the backend's CORS policy allows, e.g.
# https://app.example.com,https://<lan-ip>:3000
# Dev fallback: http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:3001
FRONTEND_ORIGINS=

# Base URL used to build links inside verification/reset emails, e.g.
# https://app.example.com. Dev fallback: http://localhost:3000
APP_BASE_URL=

# The single rebrand knob for the whole SaaS. Dev fallback: Stampd
PLATFORM_NAME=Stampd

# --- Google Sign-In (optional — the Google button just hides itself if unset) ---

# Same OAuth 2.0 Web application Client ID as the frontend's
# VITE_GOOGLE_CLIENT_ID (frontend/.env) — only ID-token verification is used,
# no client secret needed.
GOOGLE_CLIENT_ID=

# --- SMTP email (optional — emails are stubbed to the console log if unset) ---

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@stampd.co

# --- Google Places reviews (optional, legacy — see task chip re: removal) ---

GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
